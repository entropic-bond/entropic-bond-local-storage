{
  "name": "@entropic-bond/local-storage",
  "type": "module",
  "version": "1.0.0",
  "description": "LocalStorage plugin for Entropic Bond",
  "main": "./lib/entropic-bond-local-storage.umd.cjs",
  "module": "./lib/entropic-bond-local-storage.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/entropic-bond-local-storage.js",
      "require": "./lib/entropic-bond-local-storage.umd.cjs"
    }
  },
  "types": "./lib/index.d.ts",
  "files": ["lib"],
  "publishConfig": {
    "access": "public",
    "branches": [
      "master"
    ]
  },
  "release": {
    "plugins": [
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "scripts": {
    "test": "vitest",
    "build": "vite build",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/entropic-bond/entropic-bond-local-storage.git"
  },
  "keywords": [
    "localStorage",
    "entropic bond"
  ],
  "author": "Josep Seto",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/entropic-bond/entropic-bond-local-storage/issues"
  },
  "homepage": "https://github.com/entropic-bond/entropic-bond-local-storage#readme",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "entropic-bond": "^1.59.5",
    "happy-dom": "^17.4.4",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
